# ============================================================
# AgentHub Environment Variables
# Copy this file to .env and fill in your values
# .env is git-ignored; .env.example is committed
# ============================================================

# -----------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL_ID=deepseek-v4-pro
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
DATABASE_URL=postgresql://agenthub:agenthub@localhost:5432/agenthub
DB_POOL_MIN=2
DB_POOL_MAX=10

# -----------------------------------------------------------
# Redis
# -----------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------
# Message Queue (RabbitMQ)
# -----------------------------------------------------------
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# -----------------------------------------------------------
# Service Discovery (inter-service URLs)
# -----------------------------------------------------------
CORE_ENGINE_URL=http://localhost:3001
MCP_GATEWAY_URL=http://localhost:8080
SKILL_REGISTRY_URL=http://localhost:3002
KNOWLEDGE_BASE_URL=http://localhost:3003
OBSERVABILITY_URL=http://localhost:3004

# -----------------------------------------------------------
# Service Ports
# -----------------------------------------------------------
CORE_ENGINE_PORT=3001
MCP_GATEWAY_PORT=8080
SKILL_REGISTRY_PORT=3002
KNOWLEDGE_BASE_PORT=3003
OBSERVABILITY_PORT=3004

# -----------------------------------------------------------
# Strategy Selection (pluggable implementations)
# -----------------------------------------------------------
AGENT_ADAPTER=deepseek           # deepseek | anthropic | openai
EMBEDDING_STRATEGY=deepseek      # deepseek | openai | local-bge
CHUNKING_STRATEGY=recursive      # recursive | semantic | code
VECTOR_BACKEND=pgvector          # pgvector | faiss | chromadb
QUEUE_BACKEND=rabbitmq           # rabbitmq | redis | nats
EXECUTION_STRATEGY=dag           # dag | sequential | parallel
TRANSPORT_STRATEGY=sse           # sse | streamable-http
AUTH_STRATEGY=api-key            # api-key | oauth2 | mtls | noop

# -----------------------------------------------------------
# Auth (M6)
# -----------------------------------------------------------
AGENTHUB_API_KEYS=               # Comma-separated list of valid API keys

# -----------------------------------------------------------
# Observability Client (M6 C1)
# -----------------------------------------------------------
# "best-effort" = log-only (no cross-service dependency)
# "http"         = POST to OBSERVABILITY_URL API
OBSERVABILITY_CLIENT=best-effort

# -----------------------------------------------------------
# Reliability (M6 Circuit Breaker / Rate Limiting / Cost)
# -----------------------------------------------------------
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
RATE_LIMIT_TOKENS_PER_INTERVAL=100
RATE_LIMIT_INTERVAL_SECONDS=60
MAX_TOKENS_PER_RUN=100000
MAX_COST_PER_SESSION=5.00
MAX_DAILY_COST=50.00

# -----------------------------------------------------------
# Layer 5 — Cross-Review (M6 B5)
# -----------------------------------------------------------
# Consensus mode: majority_vote | unanimous | threshold
CROSS_REVIEW_CONSENSUS=majority_vote
# Maximum auto-fix rounds when consensus fails
CROSS_REVIEW_MAX_ROUNDS=3
# Number of independent reviewer agents
CROSS_REVIEW_REVIEWER_COUNT=3

# -----------------------------------------------------------
# Layer 6 — Safety Net (M6 B6)
# -----------------------------------------------------------
# Enable/disable individual safety gates
SAFETY_NET_ENABLE_RATE_LIMITER=true
SAFETY_NET_ENABLE_COST_GUARD=true
SAFETY_NET_ENABLE_CIRCUIT_BREAKER=true

# -----------------------------------------------------------
# Logging
# -----------------------------------------------------------
LOG_LEVEL=info                   # trace | debug | info | warn | error | fatal
LOG_FORMAT=json                  # json | pretty (pretty only for dev)

# -----------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------
ENABLE_HITL=false                # Human-in-the-loop (Phase 2)
ENABLE_COST_TRACKING=true        # Token cost tracking
ENABLE_AUDIT_LOG=true            # SHA-256 chained audit log

# -----------------------------------------------------------
# API Gateway (Phase 2+)
# -----------------------------------------------------------
API_GATEWAY_PORT=3000
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------
# Observability (Phase 2+)
# -----------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3005
