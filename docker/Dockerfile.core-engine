FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml .npmrc package.json tsconfig.json ./
COPY packages/contracts/package.json packages/contracts/
COPY packages/shared/package.json packages/shared/
COPY services/core-engine/package.json services/core-engine/
COPY services/skill-registry/package.json services/skill-registry/
COPY services/knowledge-base/package.json services/knowledge-base/
COPY services/observability/package.json services/observability/
RUN pnpm install --frozen-lockfile

FROM deps AS build
COPY packages/contracts/src packages/contracts/src
COPY packages/shared/src packages/shared/src
COPY services/core-engine/src services/core-engine/src
RUN pnpm --filter @agenthub/core-engine build

FROM base AS runner
COPY --from=deps /app/node_modules node_modules
COPY --from=build /app/packages/contracts/dist packages/contracts/dist
COPY --from=build /app/packages/shared/dist packages/shared/dist
COPY --from=build /app/services/core-engine/dist services/core-engine/dist
EXPOSE 3001
CMD ["node", "services/core-engine/dist/index.js"]
