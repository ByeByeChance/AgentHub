FROM golang:1.24-alpine AS build
WORKDIR /app
COPY services/mcp-gateway/go.mod services/mcp-gateway/go.sum* ./
RUN go mod download 2>/dev/null || true
COPY services/mcp-gateway/ ./
RUN CGO_ENABLED=0 go build -o /mcp-gateway .

FROM alpine:3.21
RUN apk add --no-cache curl
COPY --from=build /mcp-gateway /usr/local/bin/mcp-gateway
EXPOSE 8080
CMD ["mcp-gateway"]
