FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml .npmrc package.json tsconfig.json ./
COPY packages/contracts/package.json packages/contracts/
COPY packages/shared/package.json packages/shared/
COPY services/core-engine/package.json services/core-engine/
COPY services/skill-registry/package.json services/skill-registry/
COPY services/knowledge-base/package.json services/knowledge-base/
COPY services/observability/package.json services/observability/
COPY frontend/package.json frontend/
RUN pnpm install --frozen-lockfile

FROM deps AS build
COPY packages/contracts/src packages/contracts/src
COPY packages/shared/src packages/shared/src
COPY frontend/src frontend/src
COPY frontend/next.config.ts frontend/next.config.ts
COPY frontend/tsconfig.json frontend/tsconfig.json
COPY frontend/next-env.d.ts frontend/next-env.d.ts
RUN pnpm --filter @agenthub/frontend build

FROM base AS runner
ENV NODE_ENV=production
WORKDIR /app/frontend
COPY --from=deps /app/node_modules /app/node_modules
COPY --from=build /app/frontend/.next .next
COPY --from=build /app/frontend/next.config.ts next.config.ts
COPY --from=build /app/frontend/package.json package.json
COPY --from=build /app/frontend/tsconfig.json tsconfig.json
COPY --from=build /app/packages/contracts/dist /app/packages/contracts/dist
COPY --from=build /app/packages/shared/dist /app/packages/shared/dist
EXPOSE 3000
CMD ["node", "/app/node_modules/.bin/next", "start", "--port", "3000"]
